<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.app.globalgates.mapper.PostHashtagMapper">

    <!-- 태그 추가 -->
    <insert id="insert" useGeneratedKeys="true" keyProperty="id">
        insert into tbl_post_hashtag (tag_name)
        values (#{tagName})
    </insert>

    <!-- 게시글에 연결된 태그 목록 -->
    <select id="selectAllByPostId">
        select h.id, h.tag_name, h.created_datetime
        from tbl_post_hashtag h
                 join tbl_post_hashtag_rel r on h.id = r.hashtag_id
        where r.post_id = #{postId}
    </select>

    <!-- 태그명으로 조회 -->
    <select id="selectByTagName">
        select id, tag_name, created_datetime
        from tbl_post_hashtag
        where tag_name = #{tagName}
    </select>

    <!-- 전체 태그 목록 (정해진 태그 선택용) -->
    <select id="selectAll">
        select id, tag_name, created_datetime
        from tbl_post_hashtag
        order by tag_name
    </select>

    <!-- 게시글-태그 관계 추가 -->
    <insert id="insertRel">
        insert into tbl_post_hashtag_rel (post_id, hashtag_id)
        values (#{postId}, #{hashtagId})
    </insert>

    <!-- 게시글-태그 관계 전체 삭제 (수정 시) -->
    <delete id="deleteRelByPostId">
        delete from tbl_post_hashtag_rel
        where post_id = #{postId}
    </delete>
</mapper>
