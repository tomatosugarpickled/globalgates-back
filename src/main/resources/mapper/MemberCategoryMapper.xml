<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.app.globalgates.mapper.CategoryMemberMapper">
    <insert id="insert">
        insert into tbl_member_category_rel (member_id, category_id)
        values (#{memberId}, #{categoryId})
    </insert>

    <select id="selectByMemberId">
        select member_id, category_id
        from tbl_member_category_rel
        where member_id = #{memberId}
    </select>

    <delete id="deleteByMemberId">
        delete from tbl_member_category_rel
        where member_id = #{memberId}
    </delete>

    <delete id="delete">
        delete from tbl_member_category_rel
        where member_id = #{memberId}
          and category_id = #{categoryId}
    </delete>

</mapper>