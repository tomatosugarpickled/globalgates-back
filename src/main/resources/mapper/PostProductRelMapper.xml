<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.app.globalgates.mapper.PostProductRelMapper">

    <insert id="insert" useGeneratedKeys="true" keyProperty="id">
        insert into tbl_post_product_rel (post_id, product_post_id)
        values (#{postId}, #{productPostId})
    </insert>

    <delete id="deleteByPostId">
        delete
        from tbl_post_product_rel
        where post_id = #{postId}
    </delete>

    <select id="selectByPostId">
        select id, post_id, product_post_id
        from tbl_post_product_rel
        where post_id = #{postId}
    </select>

</mapper>
